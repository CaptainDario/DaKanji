-- Create the cost table with the correct schema for the editdist3 algorithm.
CREATE TABLE IF NOT EXISTS hiragana_spellfix_cost(
  iLang INT,   -- The language ID
  cFrom TEXT,  -- Convert text from this
  cTo   TEXT,  -- Convert text into this
  iCost INT    -- The cost of doing the conversion
);

-- Populate the cost table with a comprehensive set of rules for Japanese.
-- A lower iCost means the characters are considered more similar.
-- The default substitution cost is 100.
populateHiraganaSpellfixCostTable:
  INSERT OR IGNORE INTO hiragana_spellfix_cost(iLang, cFrom, cTo, iCost) VALUES
    -- ======================================================================
    -- Category 1: Voiced (dakuten) & Semi-voiced (handakuten) Variants
    -- Cost: 10 (very similar)
    -- ======================================================================
    -- K-line: かきくけこ ↔ がぎぐげご
    (0, 'か', 'が', 10), (0, 'が', 'か', 10),
    (0, 'き', 'ぎ', 10), (0, 'ぎ', 'き', 10),
    (0, 'く', 'ぐ', 10), (0, 'ぐ', 'く', 10),
    (0, 'け', 'げ', 10), (0, 'げ', 'け', 10),
    (0, 'こ', 'ご', 10), (0, 'ご', 'こ', 10),
    -- S-line: さしすせそ ↔ ざじずぜぞ
    (0, 'さ', 'ざ', 10), (0, 'ざ', 'さ', 10),
    (0, 'し', 'じ', 10), (0, 'じ', 'し', 10),
    (0, 'す', 'ず', 10), (0, 'ず', 'す', 10),
    (0, 'せ', 'ぜ', 10), (0, 'ぜ', 'せ', 10),
    (0, 'そ', 'ぞ', 10), (0, 'ぞ', 'そ', 10),
    -- T-line: たちつてと ↔ だぢづでど
    (0, 'た', 'だ', 10), (0, 'だ', 'た', 10),
    (0, 'ち', 'ぢ', 10), (0, 'ぢ', 'ち', 10),
    (0, 'ち', 'じ', 10), (0, 'じ', 'ち', 10),
    (0, 'つ', 'づ', 10), (0, 'づ', 'つ', 10),
    (0, 'て', 'で', 10), (0, 'で', 'て', 10),
    (0, 'と', 'ど', 10), (0, 'ど', 'と', 10),
    -- H-line: はひふへほ ↔ ばびぶべぼ ↔ ぱぴぷぺぽ
    (0, 'は', 'ば', 10), (0, 'ば', 'は', 10),
    (0, 'は', 'ぱ', 10), (0, 'ぱ', 'は', 10),
    (0, 'ば', 'ぱ', 10), (0, 'ぱ', 'ば', 10),
    (0, 'ひ', 'び', 10), (0, 'び', 'ひ', 10),
    (0, 'ひ', 'ぴ', 10), (0, 'ぴ', 'ひ', 10),
    (0, 'び', 'ぴ', 10), (0, 'ぴ', 'び', 10),
    (0, 'ふ', 'ぶ', 10), (0, 'ぶ', 'ふ', 10),
    (0, 'ふ', 'ぷ', 10), (0, 'ぷ', 'ふ', 10),
    (0, 'ぶ', 'ぷ', 10), (0, 'ぷ', 'ぶ', 10),
    (0, 'へ', 'べ', 10), (0, 'べ', 'へ', 10),
    (0, 'へ', 'ぺ', 10), (0, 'ぺ', 'へ', 10),
    (0, 'べ', 'ぺ', 10), (0, 'ぺ', 'べ', 10),
    (0, 'ほ', 'ぼ', 10), (0, 'ぼ', 'ほ', 10),
    (0, 'ほ', 'ぽ', 10), (0, 'ぽ', 'ほ', 10),
    (0, 'ぼ', 'ぽ', 10), (0, 'ぽ', 'ぼ', 10),

    -- ======================================================================
    -- Category 2: Phonetically Identical or Near-Identical (Yotsugana)
    -- Cost: 5 (functionally identical in modern Japanese)
    -- ======================================================================
    (0, 'じ', 'ぢ', 5), (0, 'ぢ', 'じ', 5),
    (0, 'ず', 'づ', 5), (0, 'づ', 'ず', 5),

    -- ======================================================================
    -- Category 3: Small vs. Large Kana (Yōon, Sokuon, Vowels)
    -- Cost: 20 (common typing mistake)
    -- ======================================================================
    (0, 'つ', 'っ', 20), (0, 'っ', 'つ', 20),
    (0, 'や', 'ゃ', 20), (0, 'ゃ', 'や', 20),
    (0, 'ゆ', 'ゅ', 20), (0, 'ゅ', 'ゆ', 20),
    (0, 'よ', 'ょ', 20), (0, 'ょ', 'よ', 20),
    (0, 'あ', 'ぁ', 20), (0, 'ぁ', 'あ', 20),
    (0, 'い', 'ぃ', 20), (0, 'ぃ', 'い', 20),
    (0, 'う', 'ぅ', 20), (0, 'ぅ', 'う', 20),
    (0, 'え', 'ぇ', 20), (0, 'ぇ', 'え', 20),
    (0, 'お', 'ぉ', 20), (0, 'ぉ', 'お', 20),

    -- ======================================================================
    -- Category 4: Long Vowel Sound Confusion
    -- Cost: 25 (common phonetic/transcription error)
    -- ======================================================================
    (0, 'おう', 'おお', 25), (0, 'おお', 'おう', 25),
    (0, 'えい', 'ええ', 25), (0, 'ええ', 'えい', 25),
    (0, 'こう', 'こお', 25), (0, 'こお', 'こう', 25),

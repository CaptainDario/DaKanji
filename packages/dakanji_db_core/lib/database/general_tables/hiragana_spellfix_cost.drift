    (0, 'ろう', 'ろお', 25), (0, 'ろお', 'ろう', 25),
    (0, 'ごう', 'ごお', 25), (0, 'ごお', 'ごう', 25),
    (0, 'ぞう', 'ぞお', 25), (0, 'ぞお', 'ぞう', 25),
    (0, 'どう', 'どお', 25), (0, 'どお', 'どう', 25),
    (0, 'ぼう', 'ぼお', 25), (0, 'ぼお', 'ぼう', 25),
    (0, 'ぽう', 'ぽお', 25), (0, 'ぽお', 'ぽう', 25),
    (0, 'せい', 'せえ', 25), (0, 'せえ', 'せい', 25),
    (0, 'てい', 'てえ', 25), (0, 'てえ', 'てい', 25),
    (0, 'ねい', 'ねえ', 25), (0, 'ねえ', 'ねい', 25),
    (0, 'へい', 'へえ', 25), (0, 'へえ', 'へい', 25),
    (0, 'めい', 'めえ', 25), (0, 'めえ', 'めい', 25),
    (0, 'れい', 'れえ', 25), (0, 'れえ', 'れい', 25),
    (0, 'げい', 'げえ', 25), (0, 'げえ', 'げい', 25),
    (0, 'ぜい', 'ぜえ', 25), (0, 'ぜえ', 'ぜい', 25),
    (0, 'でい', 'でえ', 25), (0, 'でえ', 'でい', 25),
    (0, 'べい', 'べえ', 25), (0, 'べえ', 'べい', 25),
    (0, 'ぺい', 'ぺえ', 25), (0, 'ぺえ', 'ぺい', 25),

    -- ======================================================================
    -- Category 5: Visually Similar Kana
    -- Cost: 40 (recognition/writing error)
    -- ======================================================================
    (0, 'ぬ', 'め', 40), (0, 'め', 'ぬ', 40),
    (0, 'ね', 'れ', 40), (0, 'れ', 'ね', 40),
    (0, 'わ', 'れ', 40), (0, 'れ', 'わ', 40),
    (0, 'わ', 'ね', 40), (0, 'ね', 'わ', 40),
    (0, 'は', 'ほ', 40), (0, 'ほ', 'は', 40),
    (0, 'る', 'ろ', 40), (0, 'ろ', 'る', 40),
    (0, 'い', 'り', 45), (0, 'り', 'い', 45),

    -- ======================================================================
    -- Category 6: Phonetically Identical Particles
    -- Cost: 15 (very common grammatical/phonetic error)
    -- ======================================================================
    (0, 'お', 'を', 15), (0, 'を', 'お', 15),
    (0, 'わ', 'は', 15), (0, 'は', 'わ', 15),
    (0, 'え', 'へ', 15), (0, 'へ', 'え', 15),

    -- ======================================================================
    -- Category 7: Auditory & Articulation Confusion
    -- Cost: 50 (errors from mishearing or similar pronunciation)
    -- ======================================================================
    -- 'shi' vs. 'hi' confusion
    (0, 'し', 'ひ', 50), (0, 'ひ', 'し', 50),
    -- 'sha' vs. 'hya' and related sounds
    (0, 'しゃ', 'ひゃ', 50), (0, 'ひゃ', 'しゃ', 50),
    (0, 'しゅ', 'ひゅ', 50), (0, 'ひゅ', 'しゅ', 50),
    (0, 'しょ', 'ひょ', 50), (0, 'ひょ', 'しょ', 50),
    -- 'chi' vs. 'ki' confusion
    (0, 'ち', 'き', 55), (0, 'き', 'ち', 55),
    -- 'cha' vs. 'kya' and related sounds
    (0, 'ちゃ', 'きゃ', 55), (0, 'きゃ', 'ちゃ', 55),
    (0, 'ちゅ', 'きゅ', 55), (0, 'きゅ', 'ちゅ', 55),
    (0, 'ちょ', 'きょ', 55), (0, 'きょ', 'ちょ', 55),

    -- ======================================================================
    -- Category 8: Yōon (Contracted Sound) Omission
    -- Cost: 60 (common romaji input error, e.g., typing 'sa' instead of 'sha')
    -- ======================================================================
    -- K-line
    (0, 'か', 'きゃ', 60), (0, 'きゃ', 'か', 60),
    (0, 'く', 'きゅ', 60), (0, 'きゅ', 'く', 60),
    (0, 'こ', 'きょ', 60), (0, 'きょ', 'こ', 60),
    -- S-line
    (0, 'さ', 'しゃ', 60), (0, 'しゃ', 'さ', 60),
    (0, 'す', 'しゅ', 60), (0, 'しゅ', 'す', 60),
    (0, 'そ', 'しょ', 60), (0, 'しょ', 'そ', 60),
    -- T-line
    (0, 'た', 'ちゃ', 60), (0, 'ちゃ', 'た', 60),
    (0, 'つ', 'ちゅ', 60), (0, 'ちゅ', 'つ', 60),
    (0, 'と', 'ちょ', 60), (0, 'ちょ', 'と', 60),
    -- N-line
    (0, 'な', 'にゃ', 60), (0, 'にゃ', 'な', 60),
    (0, 'ぬ', 'にゅ', 60), (0, 'にゅ', 'ぬ', 60),
    (0, 'の', 'にょ', 60), (0, 'にょ', 'の', 60),
    -- H-line
    (0, 'は', 'ひゃ', 60), (0, 'ひゃ', 'は', 60),
    (0, 'ふ', 'ひゅ', 60), (0, 'ひゅ', 'ふ', 60),

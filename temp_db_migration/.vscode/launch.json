{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "da_db",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "UI search example (debug)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}/packages/da_db_ui/examples/search"
        },
        {
            "name": "UI search example (profile)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}/packages/da_db_ui/examples/search"
        },
        {
            "name": "Attach to Dart Build",
            "request": "attach",
            "type": "dart",
            "vmServiceUri": "${command:dart.promptForVmService}"
        }
    ]
}